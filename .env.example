# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_BASE_URL=https://api.buildflow.in
FRONTEND_URL=http://localhost:5173

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=buildflow

# ─── Security ──────────────────────────────────────────────────────────────────
# Required to create manager accounts — keep this secret and share only with trusted admins
MANAGER_CREATION_KEY=replace_with_a_strong_random_secret_key

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_strong_random_secret_min_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── AWS (S3 + SES) ────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# S3
AWS_S3_BUCKET_NAME=buildflow-assets
AWS_S3_PUBLIC_BASE_URL=

# Cloudflare R2 (S3-compatible object storage)
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET_NAME=buildflow-profile-assets
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_PUBLIC_BASE_URL=https://pub-your-bucket-id.r2.dev

# SES  (use a verified domain/email in AWS SES)
AWS_SES_REGION=ap-south-1
AWS_SES_FROM_EMAIL=noreply@buildflow.in
AWS_SES_FROM_NAME=BuildFlow

# ─── Exotel ────────────────────────────────────────────────────────────────────
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_ACCOUNT_SID=your_exotel_account_sid
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_EXOPHONE=+910000000000
EXOTEL_RECORDING_ENABLED=true
EXOTEL_RECORDING_CHANNELS=dual

# ─── Lead Source Integrations ──────────────────────────────────────────────────
# Meta (Facebook / Instagram Lead Ads)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_webhook_verify_token

# Google Ads
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://api.buildflow.in/api/integrations/google/callback

# LinkedIn Lead Gen
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=https://api.buildflow.in/api/integrations/linkedin/callback

# WhatsApp Business (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_whatsapp_webhook_verify_token
